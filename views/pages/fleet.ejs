<%- include('../partials/head', { title, active }) %>
<%- include('../partials/nav', { user, active }) %>
<section class="grid two">
  <article class="panel">
    <h1>舰队大厅</h1>
    <form id="fleet-create" class="form-stack compact"><label>舰队名<input name="name" placeholder="例如：低安遗迹回收队"></label><label>目标等级<input name="tier" type="number" min="1" max="10" value="3"></label><button class="button small">创建舰队</button></form>
    <div id="fleet-list" class="card-list">
      <% for (const fleet of fleets || []) { %>
        <div class="mini-card"><b><%= fleet.name %></b><span>状态：<%= fleet.status %>　成员：<%= fleet.members?.length || 0 %></span><button data-join-fleet="<%= fleet._id %>">加入</button></div>
      <% } %>
    </div>
  </article>
  <article class="panel">
    <h1>舰队通讯</h1>
    <div id="fleet-log" class="event-list small-list"></div>
    <form id="fleet-ping" class="chat-form"><input name="text" placeholder="舰队 Ping"><button>广播</button></form>
  </article>
</section>
<%- include('../partials/footer') %>
