{
  "name": "eve-idle-game",
  "version": "0.5.1",
  "private": true,
  "type": "module",
  "description": "EVE Idle Game, a multiplayer idle extraction game with separated static frontend, Express API, Socket.IO and MongoDB.",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "seed": "node scripts/seedDatabase.js",
    "fetch:sde": "node scripts/fetchSde.js",
    "import:sde": "node scripts/importSde.js",
    "build:sde-cache": "node scripts/buildStaticSdeCache.js",
    "scan:sde": "node scripts/scanSdeDictionary.js",
    "sde:dictionary": "node scripts/scanSdeDictionary.js",
    "sde:skills": "node scripts/extractSdeSkills.js",
    "smoke": "node tests/smoke-no-db.js && node tests/combat-system-smoke.js && node tests/dogma-mapper-smoke.js && node tests/skills-fitting-smoke.js && node tests/sde-dictionary-smoke.js && node tests/static-sde-store-smoke.js",
    "check": "node tests/check-syntax.js",
    "smoke:combat": "node tests/combat-system-smoke.js",
    "smoke:dogma": "node tests/dogma-mapper-smoke.js",
    "smoke:fitting": "node tests/skills-fitting-smoke.js",
    "smoke:sde-dictionary": "node tests/sde-dictionary-smoke.js",
    "smoke:static-sde": "node tests/static-sde-store-smoke.js"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.0",
    "connect-mongo": "^6.0.0",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "express-rate-limit": "^8.1.0",
    "express-session": "^1.18.1",
    "helmet": "^8.1.0",
    "mongoose": "^9.7.0",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "socket.io": "^4.8.3",
    "yaml": "^2.7.0"
  },
  "devDependencies": {}
}
