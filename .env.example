# Server
NODE_ENV=development
PORT=3000
PUBLIC_ORIGIN=http://localhost:3000
SESSION_SECRET=change-this-to-a-long-random-string

# MongoDB
# MongoDB stores user/session/game state only. SDE static content should stay on disk.
MONGODB_URI=mongodb://127.0.0.1:27017/eve_sde_online_deep
MONGO_DB_NAME=eve_sde_online_deep

# Static SDE source
# Clone https://github.com/EVE-China/sde and point this to its yaml directory.
# Example: git clone https://github.com/EVE-China/sde.git ../sde
SDE_STATIC_DIR=../sde/yaml

# Game loop
TICK_MS=5000
AUTO_SEED=true
CREATE_DEMO_USERS=true

# Optional: set this and register with matching invite code to become admin.
ADMIN_INVITE_CODE=make-me-admin
