# Server
NODE_ENV=development
PORT=3000
PUBLIC_ORIGIN=http://localhost:3000
SESSION_SECRET=change-this-to-a-long-random-string

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/eve_sde_online_deep
MONGO_DB_NAME=eve_sde_online_deep

# Game loop
TICK_MS=5000
AUTO_SEED=true
CREATE_DEMO_USERS=true

# Optional: set this and register with matching invite code to become admin.
ADMIN_INVITE_CODE=make-me-admin
